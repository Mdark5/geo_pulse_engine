# Supabase project (service role key required for write access to ingestion tables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bitget public WebSocket (v2) — defaults are usually fine
BITGET_WS_URL=wss://ws.bitget.com/v2/ws/public
BITGET_INST_TYPE=USDT-FUTURES
# Comma-separated list of symbols to track, matched against public.projects
BITGET_SYMBOLS=BTCUSDT,ETHUSDT
# books1 / books5 / books15 — snapshot-style depth channels (no incremental merge needed)
BITGET_ORDERBOOK_CHANNEL=books15
ORDERBOOK_DEPTH_LEVELS=15

# Throttling: minimum time between persisted snapshots per symbol
ORDERBOOK_SNAPSHOT_MIN_INTERVAL_MS=500
OPEN_INTEREST_MIN_INTERVAL_MS=5000
FUNDING_RATE_MIN_INTERVAL_MS=5000

# Batching for write throughput
BATCH_FLUSH_INTERVAL_MS=250
BATCH_MAX_SIZE=500

# WebSocket keepalive / liveness
WS_PING_INTERVAL_MS=25000
WS_STALE_TIMEOUT_MS=60000

# Reconnect backoff
RECONNECT_BASE_DELAY_MS=1000
RECONNECT_MAX_DELAY_MS=30000

# Hard bounds so network stalls can never hang the process
SUPABASE_REQUEST_TIMEOUT_MS=10000
SHUTDOWN_TIMEOUT_MS=15000

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
