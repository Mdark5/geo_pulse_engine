{
  "name": "market-ingestion",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time ingestion engine that streams Bitget USDT-M futures market data (trades, order book, open interest, funding rates) into the geo_pulse_engine Supabase market-intelligence schema.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
